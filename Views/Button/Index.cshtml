@model IEnumerable<ButtonGrid.Models.ButtonModel>

    <!-- css from external file button.css-->
    <link rel="stylesheet" href="css/buttons.css" />

<h2>The time is @DateTime.Now</h2>
<form asp-action ="ButtonClick">
    <div class="container">
        @for(int i = 0; i<Model.Count(); i++)
        {
            if( i % 5 == 0)
            {
                <div style="width: 100%;"></div>
            }

            var button = Model.ElementAt(i);
            <div class="game-button" data-id="@button.Id">
                <button type="submit" name="id" value="@button.Id">
                    <img src="/img/@button.ButtonImage" alt="Button" />
                    <div>@button.Id, @button.ButtonState</div>
                </button>
            </div>
        }
    </div>
</form>